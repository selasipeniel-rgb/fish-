// Simple SVG sparkline
const Sparkline = ({ data, color = "#4fc97e", height = 50, width = 200 }) => {
  if (!data || data.length < 2) return <div style={{ height, width, display: "flex", alignItems: "center", justifyContent: "center", color: "#555", fontSize: 12 }}>No data</div>;
  const min = Math.min(...data), max = Math.max(...data);
  const range = max - min || 1;
  const pts = data.map((v, i) => `${(i / (data.length - 1)) * width},${height - ((v - min) / range) * (height - 6) - 3}`).join(" ");
  return (
    <svg width={width} height={height} style={{ overflow: "visible" }}>
      <polyline points={pts} fill="none" stroke={color} strokeWidth={2} strokeLinejoin="round" strokeLinecap="round" />
      {data.map((v, i) => (
        <circle key={i} cx={(i / (data.length - 1)) * width} cy={height - ((v - min) / range) * (height - 6) - 3} r={3} fill={color} />
      ))}
    </svg>
  );
};

const WaterGauge = ({ param, value }) => {
  const pct = Math.min(100, Math.max(0, ((value - param.warn[0]) / (param.warn[1] - param.warn[0])) * 100));
  const inRange = value >= param.min && value <= param.max;
  const inWarn = value >= param.warn[0] && value <= param.warn[1];
  const color = inRange ? "#4fc97e" : inWarn ? "#f5a623" : "#e8003d";
  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13 }}>
        <span style={{ color: "#aaa" }}>{param.label}</span>
        <span style={{ color, fontWeight: 700 }}>{value}{param.unit}</span>
      </div>
      <div style={{ height: 6, background: "rgba(255,255,255,0.08)", borderRadius: 3, overflow: "hidden" }}>
        <div style={{ width: `${pct}%`, height: "100%", background: color, borderRadius: 3, transition: "width .4s" }} />
      </div>
      <div style={{ fontSize: 11, color: "#555" }}>Safe: {param.min}–{param.max}{param.unit}</div>
    </div>
  );
};

