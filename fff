                <Btn variant="ghost" style={{ fontSize: 12, padding: "6px 12px" }} onClick={e => { e.stopPropagation(); setModal("editPond"); setPondForm({ ...p }); }}>Edit</Btn>
                <Btn variant="danger" style={{ fontSize: 12, padding: "6px 12px" }} onClick={e => { e.stopPropagation(); if (confirm("Delete pond?")) { setPonds(ps => ps.filter(x => x.id !== p.id)); showToast("Pond deleted"); } }}>Delete</Btn>
              </div>
            </Card>
          );
        })}
      </div>
      {(modal === "addPond" || modal === "editPond") && (
        <Modal title={modal === "addPond" ? "Add New Pond" : "Edit Pond"} onClose={() => setModal(null)}>
          <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
            <Input label="Pond Name" value={pondForm.name} onChange={v => setPondForm(f => ({ ...f, name: v }))} />
            <Input label="Species" value={pondForm.species} onChange={v => setPondForm(f => ({ ...f, species: v }))} />
            <Input label="Capacity" type="number" value={pondForm.capacity} onChange={v => setPondForm(f => ({ ...f, capacity: +v }))} />
            <Input label="Fish Stocked" type="number" value={pondForm.stocked} onChange={v => setPondForm(f => ({ ...f, stocked: +v }))} />
            <Input label="Avg Weight (g)" type="number" value={pondForm.weight || ""} onChange={v => setPondForm(f => ({ ...f, weight: +v }))} />
            <Select label="Stage" value={pondForm.stage} onChange={v => setPondForm(f => ({ ...f, stage: v }))} options={STAGE_ORDER} />
            <Select label="Status" value={pondForm.status} onChange={v => setPondForm(f => ({ ...f, status: v }))} options={["Active", "Fallow", "Harvested", "Under Treatment"]} />
            <Btn onClick={() => {
              if (!pondForm.name) return;
              if (modal === "addPond") {
                setPonds(ps => [...ps, { ...pondForm, id: uid(), stagedAt: today(), created: today() }]);
              } else {
                setPonds(ps => ps.map(p => p.id === pondForm.id ? pondForm : p));
              }
              setModal(null); setPondForm({ name: "", species: "Tilapia", capacity: "", stocked: "", stage: "Fingerling", status: "Active" });
              showToast(modal === "addPond" ? "Pond added!" : "Pond updated!");
            }}>Save Pond</Btn>
          </div>
        </Modal>
      )}
    </div>
  );

  // ── STAGES ──────────────────────────────────────────────────────────────────
  const Stages = () => {
    const advanceStage = (pond) => {
      const idx = STAGE_ORDER.indexOf(pond.stage);
      if (idx < STAGE_ORDER.length - 1) {
        setPonds(ps => ps.map(p => p.id === pond.id ? { ...p, stage: STAGE_ORDER[idx + 1], stagedAt: today() } : p));
        showToast(`${pond.name} advanced to ${STAGE_ORDER[idx + 1]}`);
      }
    };
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Farm Stage Management</h2>
        {activePonds.map(p => {
          const stageIdx = STAGE_ORDER.indexOf(p.stage);
          const daysInStage = daysBetween(p.stagedAt, today());
          const maxDays = STAGE_DAYS[p.stage] || 1;
          const stagePct = Math.min(100, Math.round((daysInStage / maxDays) * 100));
          const daysLeft = Math.max(0, maxDays - daysInStage);
          return (
            <Card key={p.id}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 18 }}>
                <div>
                  <h3 style={{ margin: "0 0 4px", fontFamily: "'Syne', sans-serif", color: "#fff" }}>{p.name}</h3>
                  <span style={{ color: "#888", fontSize: 13 }}>{p.species} · {p.stocked.toLocaleString()} fish</span>
                </div>
                {stageIdx < STAGE_ORDER.length - 1 && <Btn onClick={() => advanceStage(p)} variant="blue">Advance Stage →</Btn>}
              </div>
              <div style={{ display: "flex", gap: 0, marginBottom: 18 }}>
                {STAGE_ORDER.map((s, i) => {
                  const active = i === stageIdx;
                  const done = i < stageIdx;
                  return (
                    <div key={s} style={{ flex: 1, textAlign: "center" }}>
                      <div style={{ display: "flex", alignItems: "center" }}>
                        <div style={{ flex: 1, height: 2, background: done ? "#4fc97e" : "rgba(255,255,255,0.1)" }} />
                        <div style={{ width: 24, height: 24, borderRadius: "50%", background: active ? "#4fc97e" : done ? "#1a7a4a" : "rgba(255,255,255,0.1)", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11, fontWeight: 800, color: active ? "#0a1a12" : done ? "#4fc97e" : "#555", flexShrink: 0 }}>
                          {done ? "✓" : i + 1}
                        </div>
                        <div style={{ flex: 1, height: 2, background: done || active ? "#4fc97e" : "rgba(255,255,255,0.1)" }} />
                      </div>
                      <div style={{ fontSize: 11, color: active ? "#4fc97e" : done ? "#666" : "#444", marginTop: 6, fontWeight: active ? 700 : 400 }}>{s}</div>
                    </div>
                  );
                })}
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 18 }}>
                <div style={{ padding: 12, background: "rgba(255,255,255,0.04)", borderRadius: 8, textAlign: "center" }}>
                  <div style={{ fontSize: 20, fontWeight: 800, color: "#4fc97e" }}>{daysInStage}d</div>
                  <div style={{ fontSize: 11, color: "#777" }}>In current stage</div>
                </div>
                <div style={{ padding: 12, background: "rgba(255,255,255,0.04)", borderRadius: 8, textAlign: "center" }}>
                  <div style={{ fontSize: 20, fontWeight: 800, color: "#f5a623" }}>{daysLeft}d</div>
                  <div style={{ fontSize: 11, color: "#777" }}>Until next stage</div>
                </div>
                <div style={{ padding: 12, background: "rgba(255,255,255,0.04)", borderRadius: 8, textAlign: "center" }}>
                  <div style={{ fontSize: 20, fontWeight: 800, color: "#38b2f5" }}>{stagePct}%</div>
                  <div style={{ fontSize: 11, color: "#777" }}>Stage progress</div>
                </div>
              </div>
              <div style={{ height: 6, background: "rgba(255,255,255,0.07)", borderRadius: 3, marginBottom: 18 }}>
                <div style={{ width: `${stagePct}%`, height: "100%", background: "#4fc97e", borderRadius: 3, transition: "width .4s" }} />
              </div>
              <h4 style={{ margin: "0 0 10px", fontSize: 13, color: "#888", textTransform: "uppercase", letterSpacing: 0.5 }}>Stage Tasks for {p.stage}</h4>
              <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
                {(STAGE_TASKS[p.stage] || []).map((t, i) => (
                  <div key={i} style={{ padding: "8px 12px", background: "rgba(79,201,126,0.05)", borderRadius: 7, fontSize: 13, color: "#ccc", borderLeft: "2px solid #4fc97e" }}>✦ {t}</div>
                ))}
              </div>
            </Card>
          );
        })}
      </div>
    );
  };

  // ── ACTIVITIES ──────────────────────────────────────────────────────────────
  const [actForm, setActForm] = useState({ pondId: ponds[0]?.id || "", type: "Feeding", date: today(), qty: "", note: "", status: "Done" });

  const Activities = () => {
    const filtered = selectedPond ? activities.filter(a => a.pondId === selectedPond) : activities;
    const sorted = [...filtered].sort((a, b) => b.date.localeCompare(a.date));
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Activity Logger</h2>
          <div style={{ display: "flex", gap: 10 }}>
            <Select label="" value={selectedPond || ""} onChange={v => setSelectedPond(v || null)} options={[{ value: "", label: "All Ponds" }, ...ponds.map(p => ({ value: p.id, label: p.name }))]} />
            <Btn onClick={() => setModal("addActivity")}>+ Log Activity</Btn>
          </div>
        </div>
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          {sorted.length === 0 ? <Card><p style={{ color: "#555", textAlign: "center" }}>No activities logged yet</p></Card> :
            sorted.map(a => {
              const pond = ponds.find(p => p.id === a.pondId);
              const statusColor = a.status === "Done" ? "#4fc97e" : a.status === "Delayed" ? "#f5a623" : "#e8003d";
              return (
                <Card key={a.id} style={{ display: "flex", alignItems: "center", gap: 16, padding: "14px 18px" }}>
                  <div style={{ width: 40, height: 40, borderRadius: 10, background: "rgba(79,201,126,0.12)", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18, flexShrink: 0 }}>
                    {{ Feeding: "🍽️", "Water Change": "💧", Medication: "💊", Harvesting: "🎣", Stocking: "🐟" }[a.type] || "📝"}
                  </div>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
                      <span style={{ fontWeight: 700, color: "#ddd", fontSize: 14 }}>{a.type}</span>
                      {pond && <span style={{ fontSize: 12, color: "#4fc97e", background: "rgba(79,201,126,0.12)", padding: "2px 8px", borderRadius: 10 }}>{pond.name}</span>}
                    </div>
                    <div style={{ fontSize: 12, color: "#666", marginTop: 3 }}>{fmt(a.date)} {a.qty && `· ${a.qty}`} {a.note && `· ${a.note}`}</div>
                  </div>
                  <Badge color={a.status === "Done" ? "green" : a.status === "Delayed" ? "yellow" : "red"}>{a.status}</Badge>
                  <button onClick={() => setActivities(acts => acts.filter(x => x.id !== a.id))} style={{ background: "none", border: "none", color: "#444", cursor: "pointer", fontSize: 16 }}>×</button>
                </Card>
              );
            })}
        </div>
        {modal === "addActivity" && (
          <Modal title="Log Activity" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Select label="Pond" value={actForm.pondId} onChange={v => setActForm(f => ({ ...f, pondId: v }))} options={ponds.map(p => ({ value: p.id, label: p.name }))} />
              <Select label="Activity Type" value={actForm.type} onChange={v => setActForm(f => ({ ...f, type: v }))} options={["Feeding", "Water Change", "Medication", "Harvesting", "Stocking", "Sampling", "Other"]} />
              <Input label="Date" type="date" value={actForm.date} onChange={v => setActForm(f => ({ ...f, date: v }))} />
              <Input label="Quantity / Amount" value={actForm.qty} onChange={v => setActForm(f => ({ ...f, qty: v }))} placeholder="e.g. 2.5 kg, 20%" />
              <Input label="Notes" value={actForm.note} onChange={v => setActForm(f => ({ ...f, note: v }))} />
              <Select label="Status" value={actForm.status} onChange={v => setActForm(f => ({ ...f, status: v }))} options={["Done", "Delayed", "Missed"]} />
              <Btn onClick={() => {
                setActivities(acts => [...acts, { ...actForm, id: uid() }]);
                setModal(null); showToast("Activity logged!");
              }}>Save Activity</Btn>
            </div>
          </Modal>
        )}
      </div>
    );
  };

  // ── WATER ──────────────────────────────────────────────────────────────────
  const [waterForm, setWaterForm] = useState({ pondId: ponds[0]?.id || "", date: today(), ph: "", temp: "", do: "", ammonia: "", turbidity: "" });

  const Water = () => {
    const pondLogs = (selectedPond ? waterLogs.filter(w => w.pondId === selectedPond) : waterLogs).sort((a, b) => b.date.localeCompare(a.date));
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", flexWrap: "wrap", gap: 10 }}>
          <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Water Quality Monitor</h2>
          <div style={{ display: "flex", gap: 10 }}>
            <Select label="" value={selectedPond || ""} onChange={v => setSelectedPond(v || null)} options={[{ value: "", label: "All Ponds" }, ...ponds.map(p => ({ value: p.id, label: p.name }))]} />
            <Btn onClick={() => setModal("addWater")}>+ Log Water</Btn>
          </div>
        </div>
        {/* Latest readings per active pond */}
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))", gap: 16 }}>
          {activePonds.filter(p => !selectedPond || p.id === selectedPond).map(p => {
            const w = latestWater[p.id];
            return (
              <Card key={p.id}>
                <h3 style={{ margin: "0 0 16px", color: "#fff", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>{p.name}</h3>
                {!w ? <p style={{ color: "#555", fontSize: 13 }}>No readings yet</p> : (
                  <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
                    <div style={{ fontSize: 11, color: "#555", marginBottom: -4 }}>Last updated: {fmt(w.date)}</div>
                    {WATER_PARAMS.map(par => w[par.key] !== undefined && <WaterGauge key={par.key} param={par} value={w[par.key]} />)}
                  </div>
                )}
              </Card>
            );
          })}
        </div>
        {/* Historical trend sparklines */}
        {WATER_PARAMS.map(par => {
          const pId = selectedPond || activePonds[0]?.id;
          const data = waterLogs.filter(w => w.pondId === pId && w[par.key] !== undefined).sort((a, b) => a.date.localeCompare(b.date)).map(w => w[par.key]);
          if (data.length < 2) return null;
          return (
            <Card key={par.key} style={{ display: "flex", gap: 20, alignItems: "center" }}>
              <div style={{ minWidth: 120 }}>
                <div style={{ fontWeight: 700, color: "#ddd", fontSize: 14 }}>{par.label}</div>
                <div style={{ color: "#888", fontSize: 12 }}>Trend</div>
              </div>
              <Sparkline data={data} width={240} height={50} />
              <div style={{ textAlign: "right", minWidth: 80 }}>
                <div style={{ fontSize: 20, fontWeight: 800, color: "#38b2f5" }}>{data[data.length - 1]}{par.unit}</div>
                <div style={{ fontSize: 11, color: "#666" }}>Latest</div>
              </div>
            </Card>
          );
        })}
        <Card>
          <h3 style={{ margin: "0 0 14px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📜 Reading History</h3>
          <div style={{ overflowX: "auto" }}>
            <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13 }}>
              <thead>
                <tr style={{ color: "#666", textAlign: "left" }}>
                  <th style={{ padding: "8px 10px" }}>Pond</th><th style={{ padding: "8px 10px" }}>Date</th>
                  {WATER_PARAMS.map(p => <th key={p.key} style={{ padding: "8px 10px" }}>{p.label}</th>)}
                </tr>
              </thead>
              <tbody>
                {pondLogs.slice(0, 20).map(w => {
                  const pond = ponds.find(p => p.id === w.pondId);
                  return (
                    <tr key={w.id} style={{ borderTop: "1px solid rgba(255,255,255,0.05)" }}>
                      <td style={{ padding: "8px 10px", color: "#4fc97e" }}>{pond?.name}</td>
                      <td style={{ padding: "8px 10px", color: "#888" }}>{fmt(w.date)}</td>
                      {WATER_PARAMS.map(par => {
                        const v = w[par.key]; const inR = v >= par.min && v <= par.max; const inW = v >= par.warn[0] && v <= par.warn[1];
                        const c = v === undefined ? "#555" : inR ? "#4fc97e" : inW ? "#f5a623" : "#e8003d";
                        return <td key={par.key} style={{ padding: "8px 10px", color: c, fontWeight: 600 }}>{v ?? "—"}</td>;
                      })}
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </Card>
        {modal === "addWater" && (
          <Modal title="Log Water Quality" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Select label="Pond" value={waterForm.pondId} onChange={v => setWaterForm(f => ({ ...f, pondId: v }))} options={ponds.map(p => ({ value: p.id, label: p.name }))} />
              <Input label="Date" type="date" value={waterForm.date} onChange={v => setWaterForm(f => ({ ...f, date: v }))} />
              {WATER_PARAMS.map(par => <Input key={par.key} label={`${par.label} (${par.unit || "–"})`} type="number" step="0.1" value={waterForm[par.key]} onChange={v => setWaterForm(f => ({ ...f, [par.key]: +v }))} placeholder={`${par.min}–${par.max}`} />)}
              <Btn onClick={() => {
                setWaterLogs(ls => [...ls, { ...waterForm, id: uid() }]);
                setModal(null); showToast("Water reading saved!");
              }}>Save Reading</Btn>
            </div>
          </Modal>
        )}
      </div>
    );
  };

  // ── FEED ──────────────────────────────────────────────────────────────────
  const [feedForm, setFeedForm] = useState({ item: "", qty: "", unit: "kg" });
  const [feedLogForm, setFeedLogForm] = useState({ pondId: ponds[0]?.id || "", date: today(), feedItem: "", qty: "", note: "" });

  const Feed = () => {
    const totalStock = feedStock.reduce((s, f) => s + f.qty, 0);
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Feed Management</h2>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
          <Card>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
              <h3 style={{ margin: 0, color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📦 Inventory</h3>
              <Btn variant="ghost" style={{ fontSize: 12, padding: "6px 12px" }} onClick={() => setModal("addFeedStock")}>+ Add Stock</Btn>
            </div>
            {totalStock < 30 && <div style={{ marginBottom: 12, padding: "8px 12px", background: "rgba(245,166,35,0.12)", borderRadius: 8, color: "#f5a623", fontSize: 13 }}>⚠️ Low feed stock — {totalStock}kg remaining</div>}
            {feedStock.map(f => (
              <div key={f.id} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "10px 0", borderBottom: "1px solid rgba(255,255,255,0.05)" }}>
                <div>
                  <div style={{ fontWeight: 700, color: "#ddd", fontSize: 14 }}>{f.item}</div>
                </div>
                <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
                  <span style={{ fontSize: 18, fontWeight: 800, color: f.qty < 20 ? "#e8003d" : "#4fc97e" }}>{f.qty} {f.unit}</span>
                  <button onClick={() => setFeedStock(fs => fs.filter(x => x.id !== f.id))} style={{ background: "none", border: "none", color: "#444", cursor: "pointer" }}>×</button>
                </div>
              </div>
            ))}
          </Card>

          <Card>
            <h3 style={{ margin: "0 0 16px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>🧮 Daily Feed Calculator</h3>
            {activePonds.map(p => {
              const biomass = (p.stocked * p.weight) / 1000;
              const pct = p.stage === "Fingerling" ? 2 : p.stage === "Juvenile" ? 3 : p.stage === "Grow-out" ? 5 : 2;
              const feedKg = ((biomass * pct) / 100).toFixed(2);
              return (
                <div key={p.id} style={{ padding: "10px 0", borderBottom: "1px solid rgba(255,255,255,0.05)" }}>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                    <div>
                      <div style={{ fontWeight: 700, color: "#ddd", fontSize: 14 }}>{p.name}</div>
                      <div style={{ fontSize: 12, color: "#666" }}>{biomass.toFixed(1)} kg biomass · {pct}% BW</div>
                    </div>
                    <div style={{ textAlign: "right" }}>
                      <div style={{ fontSize: 20, fontWeight: 800, color: "#4fc97e" }}>{feedKg} kg</div>
                      <div style={{ fontSize: 11, color: "#777" }}>per day</div>
                    </div>
                  </div>
                </div>
              );
            })}
          </Card>
        </div>

        <Card>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
            <h3 style={{ margin: 0, color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📋 Feed Log</h3>
            <Btn onClick={() => setModal("logFeed")}>+ Log Feeding</Btn>
          </div>
          {feedLogs.length === 0 ? <p style={{ color: "#555", fontSize: 13 }}>No feed logs yet</p> :
            feedLogs.slice().reverse().slice(0, 10).map(f => {
              const pond = ponds.find(p => p.id === f.pondId);
              return (
                <div key={f.id} style={{ display: "flex", gap: 12, padding: "8px 0", borderBottom: "1px solid rgba(255,255,255,0.05)", alignItems: "center" }}>
                  <span style={{ fontSize: 18 }}>🍽️</span>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontSize: 13, color: "#ddd", fontWeight: 600 }}>{pond?.name} — {f.feedItem}</div>
                    <div style={{ fontSize: 11, color: "#666" }}>{fmt(f.date)} · {f.qty} kg {f.note && `· ${f.note}`}</div>
                  </div>
                </div>
              );
            })}
        </Card>

        {modal === "addFeedStock" && (
          <Modal title="Add Feed Stock" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Input label="Feed Item Name" value={feedForm.item} onChange={v => setFeedForm(f => ({ ...f, item: v }))} placeholder="e.g. Grower Pellets 4mm" />
              <Input label="Quantity" type="number" value={feedForm.qty} onChange={v => setFeedForm(f => ({ ...f, qty: +v }))} />
              <Select label="Unit" value={feedForm.unit} onChange={v => setFeedForm(f => ({ ...f, unit: v }))} options={["kg", "bags", "tons"]} />
              <Btn onClick={() => { setFeedStock(fs => [...fs, { ...feedForm, id: uid() }]); setModal(null); setFeedForm({ item: "", qty: "", unit: "kg" }); showToast("Stock added!"); }}>Save</Btn>
            </div>
          </Modal>
        )}
        {modal === "logFeed" && (
          <Modal title="Log Feeding" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Select label="Pond" value={feedLogForm.pondId} onChange={v => setFeedLogForm(f => ({ ...f, pondId: v }))} options={ponds.map(p => ({ value: p.id, label: p.name }))} />
              <Input label="Date" type="date" value={feedLogForm.date} onChange={v => setFeedLogForm(f => ({ ...f, date: v }))} />
              <Select label="Feed Item" value={feedLogForm.feedItem} onChange={v => setFeedLogForm(f => ({ ...f, feedItem: v }))} options={[{ value: "", label: "Select…" }, ...feedStock.map(f => ({ value: f.item, label: f.item }))]} />
              <Input label="Quantity (kg)" type="number" step="0.1" value={feedLogForm.qty} onChange={v => setFeedLogForm(f => ({ ...f, qty: +v }))} />
              <Input label="Notes" value={feedLogForm.note} onChange={v => setFeedLogForm(f => ({ ...f, note: v }))} />
              <Btn onClick={() => {
                setFeedLogs(fl => [...fl, { ...feedLogForm, id: uid() }]);
                setFeedStock(fs => fs.map(f => f.item === feedLogForm.feedItem ? { ...f, qty: Math.max(0, f.qty - feedLogForm.qty) } : f));
                setModal(null); showToast("Feeding logged!");
              }}>Save</Btn>
            </div>
          </Modal>
        )}
      </div>
    );
  };

  // ── ANALYTICS ──────────────────────────────────────────────────────────────
  const Analytics = () => {
    const [finForm, setFinForm] = useState({ pondId: ponds[0]?.id || "", type: "Expense", category: "Feed", amount: "", date: today(), note: "" });
    const [growForm, setGrowForm] = useState({ pondId: ponds[0]?.id || "", date: today(), weight: "" });
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Performance & Analytics</h2>
        {/* Growth tracking */}
        <Card>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
            <h3 style={{ margin: 0, color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📈 Growth Tracking</h3>
            <Btn variant="ghost" style={{ fontSize: 12, padding: "6px 12px" }} onClick={() => setModal("logGrowth")}>+ Log Weight</Btn>
          </div>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(260px, 1fr))", gap: 16 }}>
            {activePonds.map(p => {
              const pGrowth = growthLogs.filter(g => g.pondId === p.id).sort((a, b) => a.date.localeCompare(b.date));
              const data = pGrowth.map(g => g.weight);
              const gain = data.length > 1 ? (data[data.length - 1] - data[0]).toFixed(0) : 0;
              return (
                <Card key={p.id} style={{ background: "rgba(255,255,255,0.02)", padding: "16px" }}>
                  <div style={{ fontWeight: 700, color: "#ddd", marginBottom: 12 }}>{p.name}</div>
                  <Sparkline data={data} width={220} height={60} color="#38b2f5" />
                  <div style={{ display: "flex", gap: 16, marginTop: 10 }}>
                    <div><div style={{ fontSize: 16, fontWeight: 800, color: "#4fc97e" }}>{p.weight}g</div><div style={{ fontSize: 11, color: "#777" }}>Current</div></div>
                    <div><div style={{ fontSize: 16, fontWeight: 800, color: "#38b2f5" }}>+{gain}g</div><div style={{ fontSize: 11, color: "#777" }}>Total gain</div></div>
                  </div>
                </Card>
              );
            })}
          </div>
        </Card>
        {/* Financials */}
        <Card>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
            <h3 style={{ margin: 0, color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>💰 Cost & Revenue</h3>
            <Btn variant="ghost" style={{ fontSize: 12, padding: "6px 12px" }} onClick={() => setModal("logFinancial")}>+ Add Entry</Btn>
          </div>
          {ponds.map(p => {
            const pFin = financials.filter(f => f.pondId === p.id);
            const expenses = pFin.filter(f => f.type === "Expense").reduce((s, f) => s + f.amount, 0);
            const revenue = pFin.filter(f => f.type === "Revenue").reduce((s, f) => s + f.amount, 0);
            const profit = revenue - expenses;
            return (
              <div key={p.id} style={{ padding: "12px 0", borderBottom: "1px solid rgba(255,255,255,0.05)" }}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <span style={{ fontWeight: 700, color: "#ddd" }}>{p.name}</span>
                  <div style={{ display: "flex", gap: 20 }}>
                    <div style={{ textAlign: "right" }}><div style={{ color: "#e8003d", fontWeight: 700 }}>₦{expenses.toLocaleString()}</div><div style={{ fontSize: 11, color: "#666" }}>Expenses</div></div>
                    <div style={{ textAlign: "right" }}><div style={{ color: "#4fc97e", fontWeight: 700 }}>₦{revenue.toLocaleString()}</div><div style={{ fontSize: 11, color: "#666" }}>Revenue</div></div>
                    <div style={{ textAlign: "right" }}><div style={{ color: profit >= 0 ? "#4fc97e" : "#e8003d", fontWeight: 800, fontSize: 18 }}>₦{profit.toLocaleString()}</div><div style={{ fontSize: 11, color: "#666" }}>P&L</div></div>
                  </div>
                </div>
                {profit < 0 && <div style={{ marginTop: 6, padding: "6px 10px", background: "rgba(232,0,61,0.1)", borderRadius: 6, fontSize: 12, color: "#e8003d" }}>🚨 In the red — costs exceed projections</div>}
              </div>
            );
          })}
        </Card>
        {/* Survival rate */}
        <Card>
          <h3 style={{ margin: "0 0 16px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📉 Pond Comparison</h3>
          <div style={{ overflowX: "auto" }}>
            <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13 }}>
              <thead>
                <tr style={{ color: "#666" }}>
                  {["Pond", "Species", "Stage", "Fish", "Avg Wt", "Biomass", "Utilization"].map(h => <th key={h} style={{ padding: "8px 12px", textAlign: "left" }}>{h}</th>)}
                </tr>
              </thead>
              <tbody>
                {ponds.map(p => {
                  const biomass = ((p.stocked * p.weight) / 1000).toFixed(1);
                  const util = p.capacity > 0 ? Math.round((p.stocked / p.capacity) * 100) : 0;
                  return (
                    <tr key={p.id} style={{ borderTop: "1px solid rgba(255,255,255,0.05)" }}>
                      <td style={{ padding: "10px 12px", fontWeight: 700, color: "#ddd" }}>{p.name}</td>
                      <td style={{ padding: "10px 12px", color: "#aaa" }}>{p.species}</td>
                      <td style={{ padding: "10px 12px", color: "#888" }}>{p.stage}</td>
                      <td style={{ padding: "10px 12px", color: "#4fc97e", fontWeight: 700 }}>{p.stocked.toLocaleString()}</td>
                      <td style={{ padding: "10px 12px", color: "#38b2f5" }}>{p.weight}g</td>
                      <td style={{ padding: "10px 12px", color: "#c97e4f" }}>{biomass} kg</td>
                      <td style={{ padding: "10px 12px" }}><div style={{ display: "flex", alignItems: "center", gap: 8 }}><div style={{ flex: 1, height: 6, background: "rgba(255,255,255,0.07)", borderRadius: 3 }}><div style={{ width: `${util}%`, height: "100%", background: util > 90 ? "#e8003d" : "#4fc97e", borderRadius: 3 }} /></div><span style={{ color: "#aaa", fontSize: 12 }}>{util}%</span></div></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </Card>
        {modal === "logGrowth" && (
          <Modal title="Log Growth Sample" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Select label="Pond" value={growForm.pondId} onChange={v => setGrowForm(f => ({ ...f, pondId: v }))} options={ponds.map(p => ({ value: p.id, label: p.name }))} />
              <Input label="Date" type="date" value={growForm.date} onChange={v => setGrowForm(f => ({ ...f, date: v }))} />
              <Input label="Avg Weight (g)" type="number" value={growForm.weight} onChange={v => setGrowForm(f => ({ ...f, weight: +v }))} />
              <Btn onClick={() => {
                setGrowthLogs(gl => [...gl, { ...growForm, id: uid() }]);
                setPonds(ps => ps.map(p => p.id === growForm.pondId ? { ...p, weight: +growForm.weight } : p));
                setModal(null); showToast("Growth logged!");
              }}>Save</Btn>
            </div>
          </Modal>
        )}
        {modal === "logFinancial" && (
          <Modal title="Add Financial Entry" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Select label="Pond" value={finForm.pondId} onChange={v => setFinForm(f => ({ ...f, pondId: v }))} options={ponds.map(p => ({ value: p.id, label: p.name }))} />
              <Select label="Type" value={finForm.type} onChange={v => setFinForm(f => ({ ...f, type: v }))} options={["Expense", "Revenue"]} />
              <Select label="Category" value={finForm.category} onChange={v => setFinForm(f => ({ ...f, category: v }))} options={["Feed", "Labour", "Medication", "Equipment", "Sale", "Other"]} />
              <Input label="Amount (₦)" type="number" value={finForm.amount} onChange={v => setFinForm(f => ({ ...f, amount: +v }))} />
              <Input label="Date" type="date" value={finForm.date} onChange={v => setFinForm(f => ({ ...f, date: v }))} />
              <Input label="Note" value={finForm.note} onChange={v => setFinForm(f => ({ ...f, note: v }))} />
              <Btn onClick={() => {
                setFinancials(fin => [...fin, { ...finForm, id: uid() }]);
                setModal(null); showToast("Entry saved!");
              }}>Save</Btn>
            </div>
          </Modal>
        )}
      </div>
    );
  };

  // ── HEALTH ──────────────────────────────────────────────────────────────────
  const [healthForm, setHealthForm] = useState({ pondId: ponds[0]?.id || "", date: today(), disease: "", symptoms: "", treatment: "", dosage: "", note: "" });

  const Health = () => {
    const [pondVol, setPondVol] = useState(50);
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Health & Disease Tracker</h2>
          <Btn onClick={() => setModal("logHealth")}>+ Log Health Event</Btn>
        </div>
        {/* Disease reference */}
        <Card>
          <h3 style={{ margin: "0 0 16px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📖 Disease Reference Guide</h3>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))", gap: 12 }}>
            {DISEASES.map(d => (
              <div key={d.name} style={{ padding: 14, background: "rgba(255,255,255,0.03)", borderRadius: 10, border: "1px solid rgba(255,255,255,0.07)" }}>
                <div style={{ fontWeight: 800, color: "#e8a020", marginBottom: 6, fontSize: 14 }}>{d.name}</div>
                <div style={{ fontSize: 12, color: "#888", marginBottom: 6 }}><strong style={{ color: "#aaa" }}>Symptoms:</strong> {d.symptoms}</div>
                <div style={{ fontSize: 12, color: "#888", marginBottom: 6 }}><strong style={{ color: "#aaa" }}>Remedy:</strong> {d.remedy}</div>
                <div style={{ fontSize: 12, color: "#4fc97e" }}>💊 {d.dosage}</div>
              </div>
            ))}
          </div>
        </Card>
        {/* Dosage calculator */}
        <Card>
          <h3 style={{ margin: "0 0 14px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>🧪 Medication Dosage Calculator</h3>
          <div style={{ display: "flex", gap: 16, alignItems: "flex-end", flexWrap: "wrap" }}>
            <Input label="Pond Volume (m³)" type="number" value={pondVol} onChange={setPondVol} />
            {DISEASES.map(d => {
              const mgL = parseFloat(d.dosage);
              if (isNaN(mgL)) return null;
              const totalMg = (mgL * pondVol * 1000).toFixed(0);
              return (
                <div key={d.name} style={{ padding: "10px 14px", background: "rgba(255,255,255,0.03)", borderRadius: 8, minWidth: 160 }}>
                  <div style={{ fontSize: 12, color: "#888" }}>{d.name}</div>
                  <div style={{ fontSize: 18, fontWeight: 800, color: "#38b2f5" }}>{(totalMg / 1000).toFixed(2)} g</div>
                  <div style={{ fontSize: 11, color: "#666" }}>for {pondVol}m³</div>
                </div>
              );
            })}
          </div>
        </Card>
        {/* Health log */}
        <Card>
          <h3 style={{ margin: "0 0 14px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📋 Treatment History</h3>
          {healthLogs.length === 0 ? <p style={{ color: "#555", fontSize: 13 }}>No health events logged</p> :
            healthLogs.slice().reverse().map(h => {
              const pond = ponds.find(p => p.id === h.pondId);
              return (
                <div key={h.id} style={{ padding: "12px 0", borderBottom: "1px solid rgba(255,255,255,0.05)" }}>
                  <div style={{ display: "flex", gap: 10, alignItems: "flex-start" }}>
                    <span style={{ fontSize: 20 }}>🩺</span>
                    <div>
                      <div style={{ fontWeight: 700, color: "#ddd" }}>{h.disease || "Health Event"} — <span style={{ color: "#4fc97e" }}>{pond?.name}</span></div>
                      <div style={{ fontSize: 12, color: "#888" }}>{fmt(h.date)}</div>
                      {h.symptoms && <div style={{ fontSize: 12, color: "#aaa", marginTop: 4 }}>Symptoms: {h.symptoms}</div>}
                      {h.treatment && <div style={{ fontSize: 12, color: "#38b2f5", marginTop: 2 }}>Treatment: {h.treatment} {h.dosage && `(${h.dosage})`}</div>}
                      {h.note && <div style={{ fontSize: 12, color: "#666", marginTop: 2 }}>{h.note}</div>}
                    </div>
                  </div>
                </div>
              );
            })}
        </Card>
        {modal === "logHealth" && (
          <Modal title="Log Health Event" onClose={() => setModal(null)}>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <Select label="Pond" value={healthForm.pondId} onChange={v => setHealthForm(f => ({ ...f, pondId: v }))} options={ponds.map(p => ({ value: p.id, label: p.name }))} />
              <Input label="Date" type="date" value={healthForm.date} onChange={v => setHealthForm(f => ({ ...f, date: v }))} />
              <Select label="Disease/Issue" value={healthForm.disease} onChange={v => setHealthForm(f => ({ ...f, disease: v }))} options={[{ value: "", label: "Custom / Other" }, ...DISEASES.map(d => ({ value: d.name, label: d.name }))]} />
              <Input label="Symptoms Observed" value={healthForm.symptoms} onChange={v => setHealthForm(f => ({ ...f, symptoms: v }))} />
              <Input label="Treatment Applied" value={healthForm.treatment} onChange={v => setHealthForm(f => ({ ...f, treatment: v }))} />
              <Input label="Dosage" value={healthForm.dosage} onChange={v => setHealthForm(f => ({ ...f, dosage: v }))} />
              <Input label="Notes" value={healthForm.note} onChange={v => setHealthForm(f => ({ ...f, note: v }))} />
              <Btn onClick={() => {
                setHealthLogs(hl => [...hl, { ...healthForm, id: uid() }]);
                setModal(null); showToast("Health event logged!");
              }}>Save</Btn>
            </div>
          </Modal>
        )}
      </div>
    );
  };

  // ── REPORTS ──────────────────────────────────────────────────────────────────
  const Reports = () => {
    const exportCSV = () => {
      const rows = [["Pond", "Date", "Activity", "Qty", "Note", "Status"]];
      activities.forEach(a => {
        const p = ponds.find(x => x.id === a.pondId);
        rows.push([p?.name, a.date, a.type, a.qty, a.note, a.status]);
      });
      const csv = rows.map(r => r.join(",")).join("\n");
      const blob = new Blob([csv], { type: "text/csv" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a"); a.href = url; a.download = "farm_activities.csv"; a.click();
    };
    const totalExp = financials.filter(f => f.type === "Expense").reduce((s, f) => s + f.amount, 0);
    const totalRev = financials.filter(f => f.type === "Revenue").reduce((s, f) => s + f.amount, 0);
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <h2 style={{ margin: 0, fontFamily: "'Syne', sans-serif", color: "#4fc97e" }}>Reports & Export</h2>
          <Btn onClick={exportCSV} variant="blue">⬇ Export Activities CSV</Btn>
        </div>
        {/* Summary cards */}
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))", gap: 14 }}>
          <StatCard icon="📝" label="Total Activities" value={activities.length} color="#38b2f5" />
          <StatCard icon="💧" label="Water Readings" value={waterLogs.length} color="#4fc97e" />
          <StatCard icon="🩺" label="Health Events" value={healthLogs.length} color="#e8a020" />
          <StatCard icon="💰" label="Total Expenses" value={`₦${totalExp.toLocaleString()}`} color="#e8003d" />
          <StatCard icon="📈" label="Total Revenue" value={`₦${totalRev.toLocaleString()}`} color="#4fc97e" />
          <StatCard icon="🏦" label="Net P&L" value={`₦${(totalRev - totalExp).toLocaleString()}`} color={totalRev - totalExp >= 0 ? "#4fc97e" : "#e8003d"} />
        </div>
        {/* Weekly summary */}
        <Card>
          <h3 style={{ margin: "0 0 16px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>📅 Weekly Farm Summary</h3>
          {ponds.map(p => {
            const pActs = activities.filter(a => a.pondId === p.id && a.date >= new Date(Date.now() - 7 * 86400000).toISOString().slice(0, 10));
            const w = latestWater[p.id];
            return (
              <div key={p.id} style={{ marginBottom: 20, padding: 16, background: "rgba(255,255,255,0.03)", borderRadius: 10 }}>
                <div style={{ fontWeight: 800, color: "#fff", fontFamily: "'Syne', sans-serif", marginBottom: 10 }}>{p.name}</div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 10 }}>
                  <div style={{ textAlign: "center" }}><div style={{ fontSize: 20, fontWeight: 800, color: "#4fc97e" }}>{pActs.length}</div><div style={{ fontSize: 11, color: "#777" }}>Activities (7d)</div></div>
                  <div style={{ textAlign: "center" }}><div style={{ fontSize: 20, fontWeight: 800, color: "#38b2f5" }}>{p.stocked}</div><div style={{ fontSize: 11, color: "#777" }}>Fish Count</div></div>
                  <div style={{ textAlign: "center" }}><div style={{ fontSize: 20, fontWeight: 800, color: w ? (getWaterStatus(p.id) === "green" ? "#4fc97e" : "#f5a623") : "#555" }}>{w ? "✓" : "?"}</div><div style={{ fontSize: 11, color: "#777" }}>Water Status</div></div>
                </div>
              </div>
            );
          })}
        </Card>
        {/* Expense breakdown */}
        <Card>
          <h3 style={{ margin: "0 0 14px", color: "#4fc97e", fontFamily: "'Syne', sans-serif", fontSize: 15 }}>💸 Expense Breakdown</h3>
          <div style={{ overflowX: "auto" }}>
            <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13 }}>
              <thead><tr style={{ color: "#666" }}>
                {["Date", "Pond", "Type", "Category", "Amount", "Note"].map(h => <th key={h} style={{ padding: "8px 10px", textAlign: "left" }}>{h}</th>)}
              </tr></thead>
              <tbody>
                {financials.slice().sort((a, b) => b.date.localeCompare(a.date)).map(f => {
                  const p = ponds.find(x => x.id === f.pondId);
                  return (
                    <tr key={f.id} style={{ borderTop: "1px solid rgba(255,255,255,0.05)" }}>
                      <td style={{ padding: "8px 10px", color: "#888" }}>{fmt(f.date)}</td>
                      <td style={{ padding: "8px 10px", color: "#4fc97e" }}>{p?.name}</td>
                      <td style={{ padding: "8px 10px" }}><Badge color={f.type === "Revenue" ? "green" : "red"}>{f.type}</Badge></td>
                      <td style={{ padding: "8px 10px", color: "#aaa" }}>{f.category}</td>
                      <td style={{ padding: "8px 10px", fontWeight: 700, color: f.type === "Revenue" ? "#4fc97e" : "#e8003d" }}>₦{f.amount.toLocaleString()}</td>
                      <td style={{ padding: "8px 10px", color: "#666" }}>{f.note}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </Card>
      </div>
    );
  };

  // ── RENDER ──────────────────────────────────────────────────────────────────
  const VIEWS = { dashboard: Dashboard, ponds: Ponds, stages: Stages, activities: Activities, water: Water, feed: Feed, analytics: Analytics, health: Health, reports: Reports };
  const View = VIEWS[tab] || Dashboard;

  return (
    <>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;600&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #060e0a; color: #ccc; font-family: 'IBM Plex Mono', monospace; }
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #1a4029; border-radius: 2px; }
        input:focus, select:focus { border-color: #4fc97e !important; box-shadow: 0 0 0 2px rgba(79,201,126,0.15); }
      `}</style>
      <div style={{ minHeight: "100vh", background: "radial-gradient(ellipse 80% 60% at 50% 0%, #0a2018 0%, #060e0a 70%)" }}>
        {/* Header */}
        <div style={{ borderBottom: "1px solid rgba(255,255,255,0.07)", padding: "0 24px", display: "flex", alignItems: "center", gap: 20, height: 58, position: "sticky", top: 0, background: "rgba(6,14,10,0.92)", backdropFilter: "blur(12px)", zIndex: 100 }}>
          <div style={{ fontFamily: "'Syne', sans-serif", fontWeight: 800, fontSize: 18, color: "#4fc97e", letterSpacing: -0.5, display: "flex", alignItems: "center", gap: 8, flexShrink: 0 }}>
            <span style={{ fontSize: 22 }}>🐟</span> AquaFarm
          </div>
          <div style={{ flex: 1, display: "flex", gap: 2, overflowX: "auto" }}>
            {TABS.map(t => (
              <button key={t.id} onClick={() => setTab(t.id)}
                style={{ padding: "6px 12px", borderRadius: 7, border: "none", cursor: "pointer", fontSize: 12, fontFamily: "'Syne', sans-serif", fontWeight: 600, whiteSpace: "nowrap", background: tab === t.id ? "rgba(79,201,126,0.15)" : "transparent", color: tab === t.id ? "#4fc97e" : "#666", transition: "all .15s" }}>
                {t.label}
              </button>
            ))}
          </div>
          <div style={{ flexShrink: 0, display: "flex", gap: 8, alignItems: "center" }}>
            {alertPonds.length > 0 && <div style={{ background: "#e8003d", color: "#fff", borderRadius: 20, padding: "3px 10px", fontSize: 11, fontWeight: 700 }}>🚨 {alertPonds.length} ALERT{alertPonds.length > 1 ? "S" : ""}</div>}
            <div style={{ fontSize: 12, color: "#555" }}>{fmt(today())}</div>
          </div>
        </div>

        {/* Content */}
        <div style={{ maxWidth: 1200, margin: "0 auto", padding: "28px 24px 60px" }}>
          <View />
        </div>

        {/* Toast */}
        {toast && (
          <div style={{ position: "fixed", bottom: 28, right: 28, background: toast.type === "success" ? "#1a7a4a" : "#a0001e", color: "#fff", padding: "12px 20px", borderRadius: 10, fontSize: 14, fontWeight: 600, boxShadow: "0 8px 32px rgba(0,0,0,0.4)", zIndex: 2000, animation: "fadeIn .2s" }}>
            {toast.msg}
          </div>
        )}
      </div>
    </>
  );
}
